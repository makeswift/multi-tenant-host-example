# Root domain the app is served from. Use "localhost" in development and your
# real domain (e.g. "example.com") in production. Tenant subdomains are resolved
# relative to this value; the bare root domain maps to the default tenant.
ROOT_DOMAIN=localhost

# Site API key used for the default tenant (the bare root domain, e.g.
# "localhost:3000" or "example.com").
DEFAULT_MAKESWIFT_SITE_API_KEY=

# Each additional tenant needs a subdomain identifier and its Site API key.
SITE_A_SUBDOMAIN=siteA
SITE_A_MAKESWIFT_SITE_API_KEY=
SITE_B_SUBDOMAIN=siteB
SITE_B_MAKESWIFT_SITE_API_KEY=
